# Default: detect text files and normalize to LF
* text=auto eol=lf

# Source code — always LF
*.py        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.sql       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.sh        text eol=lf

# Windows-only scripts MUST use CRLF or PowerShell 5.1 / cmd.exe break
*.ps1       text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.svg       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tar       binary

# Generated / lock files
package-lock.json   linguist-generated=true
yarn.lock           linguist-generated=true
pnpm-lock.yaml      linguist-generated=true
poetry.lock         linguist-generated=true
