# ===========================================================================
# PostDash env vars
# Copy to .env and fill in. Never commit .env.
# Все опциональные секреты можно оставить пустыми в Phase 0 — нужны с Phase 1+.
# ===========================================================================

# --- Runtime --------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info

# --- API ------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=3000

# --- Database (Phase 0+) ---------------------------------------------------
# Default: local Docker Postgres from `docker compose up -d postgres`.
# Remote shared/prod default: Neon Postgres.
# For Neon migrations, prefer the direct connection string. Add a separate
# runtime pool URL only after the app actually supports/needs pooling.
# Never commit real cloud credentials.
DATABASE_URL=postgresql://postdash:postdash@localhost:5432/postdash

# --- DB migrator (optional) ------------------------------------------------
# Comma-separated migration filenames where checksum drift is tolerated.
# Use this ONLY for one-time recovery (e.g. restore from backup). The flag does NOT
# accept boolean (true/yes/1) — deliberately, to prevent sticky-flag footguns.
# Use `*` or `all` for global override (with loud warning, NOT for production).
# Examples:
#   MIGRATE_ALLOW_CHECKSUM_DRIFT=0001_phase1.sql
#   MIGRATE_ALLOW_CHECKSUM_DRIFT=*
MIGRATE_ALLOW_CHECKSUM_DRIFT=

# --- Telegram (Phase 1+) ---------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
MINIAPP_URL=http://localhost:5173
MINIAPP_BUILD_VERSION=dev

# --- Mini App (Vite reads VITE_* from root .env via envDir setting) --------
VITE_API_URL=http://localhost:3000
VITE_BUILD_VERSION=dev

# --- Yandex AI Studio (Phase 4+; scaffolding in Phase 0) -------------------
# Fill these to enable Yandex AI Studio provider. Leave empty for
# template-only (Phase 0/dev). createAIProvider() also auto-detects known
# placeholder strings (e.g. "your-folder-id") and falls back to TemplateProvider.
YA_SA_KEY_JSON=
YA_FOLDER_ID=
YA_LLM_MODEL_URI=
YA_EMBED_DOC_MODEL_URI=
YA_EMBED_QUERY_MODEL_URI=
YA_LLM_REQUEST_TIMEOUT_MS=60000
YA_LLM_MAX_TOKENS=2000
YA_LLM_TEMPERATURE=0.3

# --- Observability (optional) ---------------------------------------------
# /health uses these for the `version` field, in order of preference.
# In Render the platform sets RENDER_GIT_COMMIT automatically; in other
# environments set APP_VERSION or COMMIT_SHA at deploy time.
APP_VERSION=
COMMIT_SHA=

# --- AI cost guard ---------------------------------------------------------
AI_INPUT_RUB_PER_1M_TOKENS=8
AI_OUTPUT_RUB_PER_1M_TOKENS=24
AI_EMBED_RUB_PER_1M_TOKENS=2
AI_DAILY_CAP_RUB_PER_WORKSPACE=200
AI_FALLBACK_TO_TEMPLATE=true
AI_EMBEDDING_DIM=256
AI_DEDUPE_COSINE_THRESHOLD=0.15
AI_DEDUPE_WINDOW_HOURS=48

# --- Worker (Phase 4+) -----------------------------------------------------
WORKER_CONCURRENCY=10
TASK_POLL_INTERVAL_MS=1000
TASK_LEASE_MINUTES=5
MAX_ITEMS_PER_FETCH_DEFAULT=50
AUTO_DRAFT_SCORE_THRESHOLD=7.5
MATCHING_MIN_COSINE=0.05
