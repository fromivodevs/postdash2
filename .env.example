# ====================================================================
# PostDash .env — заполни 4 строки в FILL ME, остальное не трогай.
# Cloudflared URLs обнови когда туннели перезапустишь.
# Yandex AI — заполни когда дойдёшь до Phase 4 (до этого TemplateProvider fallback).
# Database policy: architecture/database.md (Neon everywhere).
# ====================================================================

# === FILL ME (one-time per developer) ===============================
DATABASE_URL=postgresql://USER:PASS@ep-xxxx.REGION.aws.neon.tech/DBNAME?sslmode=require
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
VITE_TELEGRAM_BOT_USERNAME=

# === Dev tunnels (cloudflared) — refresh on tunnel restart ==========
TELEGRAM_WEBHOOK_URL=https://API-TUNNEL.trycloudflare.com/telegram/webhook
MINIAPP_URL=https://MINIAPP-TUNNEL.trycloudflare.com
VITE_API_URL=https://API-TUNNEL.trycloudflare.com

# === Runtime defaults (do not touch) ================================
NODE_ENV=development
LOG_LEVEL=info
API_HOST=0.0.0.0
API_PORT=3000
TELEGRAM_WEBHOOK_SECRET=pd_dev_a7K-mQ2L_w9Yx4nVc1jS
MINIAPP_BUILD_VERSION=dev
VITE_BUILD_VERSION=dev
MIGRATE_ALLOW_CHECKSUM_DRIFT=

# === Yandex AI Studio (Phase 4+) ====================================
# Empty = TemplateProvider fallback (no real AI calls). Works for Phase 0-3.
# When ready for Phase 4 (embeddings/scoring/drafts), fill these from:
#   https://console.cloud.yandex.com -> Service Accounts -> create key JSON
#   https://console.cloud.yandex.com/folders -> copy folder id
# Then replace <folder> placeholders in the 3 URIs below.
YA_SA_KEY_JSON=
YA_FOLDER_ID=
YA_LLM_MODEL_URI=
YA_EMBED_DOC_MODEL_URI=
YA_EMBED_QUERY_MODEL_URI=

# Yandex tuning defaults (Phase 4+ -- sane defaults pre-filled)
YA_LLM_REQUEST_TIMEOUT_MS=60000
YA_LLM_MAX_TOKENS=2000
YA_LLM_TEMPERATURE=0.3

# === AI cost guard (Phase 6+ -- Yandex pricing in RUB) ==============
AI_INPUT_RUB_PER_1M_TOKENS=8
AI_OUTPUT_RUB_PER_1M_TOKENS=24
AI_EMBED_RUB_PER_1M_TOKENS=2
AI_DAILY_CAP_RUB_PER_WORKSPACE=200
AI_FALLBACK_TO_TEMPLATE=true
AI_EMBEDDING_DIM=256
AI_DEDUPE_COSINE_THRESHOLD=0.15
AI_DEDUPE_WINDOW_HOURS=48

# === Worker + scoring (Phase 4-6) ===================================
WORKER_CONCURRENCY=10
TASK_POLL_INTERVAL_MS=1000
TASK_LEASE_MINUTES=5
MAX_ITEMS_PER_FETCH_DEFAULT=50
AUTO_DRAFT_SCORE_THRESHOLD=7.5
MATCHING_MIN_COSINE=0.05

# === Observability (optional, Render/Vercel set automatically) ======
APP_VERSION=
COMMIT_SHA=
