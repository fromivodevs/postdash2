{
  "name": "@postdash/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./pool": "./src/pool.ts",
    "./migrate": "./src/migrate.ts"
  },
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx --env-file=../../.env src/migrate.ts",
    "generate": "drizzle-kit generate --config=drizzle.config.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.4",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
