{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File C:/PostDash/.claude/hooks/pre-write-guard.ps1"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File C:/PostDash/.claude/hooks/block-dangerous-bash.ps1"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File C:/PostDash/.claude/hooks/format-on-edit.ps1"
          },
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File C:/PostDash/.claude/hooks/lint-on-edit.ps1"
          },
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File C:/PostDash/.claude/hooks/stage-complete-detector.ps1"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File C:/PostDash/.claude/hooks/roadmap-reminder.ps1"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File C:/PostDash/.claude/hooks/subagent-roadmap-reminder.ps1"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(npm run build:*)",
      "Bash(npm run dev:*)",
      "Bash(npm run lint:*)",
      "Bash(npm test:*)",
      "Bash(pnpm test:*)",
      "Bash(yarn test:*)",
      "Bash(pytest:*)",
      "Bash(ruff check:*)",
      "Bash(ruff format:*)",
      "Bash(eslint:*)",
      "Bash(mypy:*)",
      "Bash(pyright:*)",
      "Bash(tsc --noEmit)",
      "Bash(ls:*)",
      "Bash(pwd)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf C:*)",
      "Bash(git push --force origin main)",
      "Bash(git push --force origin master)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fdx:*)",
      "Bash(npm publish)",
      "Bash(pnpm publish)",
      "Bash(pypi-cli upload:*)",
      "Write(C:/PostDash/.env)",
      "Write(C:/PostDash/.env.local)",
      "Edit(C:/PostDash/.env)",
      "Edit(C:/PostDash/.env.local)"
    ]
  }
}
