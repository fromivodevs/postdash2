{
  "name": "postdash",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "AI-радар инфоповодов для Telegram-каналов",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "concurrently -n api,worker,miniapp -c blue,magenta,green -k --handle-input \"pnpm dev:api\" \"pnpm dev:worker\" \"pnpm dev:miniapp\"",
    "dev:api": "pnpm --filter @postdash/api dev",
    "dev:miniapp": "pnpm --filter @postdash/miniapp dev",
    "dev:worker": "pnpm --filter @postdash/worker dev",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "db:migrate": "pnpm --filter @postdash/db migrate",
    "db:generate": "pnpm --filter @postdash/db generate",
    "db:up": "docker compose up -d postgres"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "concurrently": "^9.1.2",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@9.15.0"
}
